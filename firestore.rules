rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{appName}/root {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{appName}/root/users/{uid} {
      allow read, write: if request.auth != null;
    }

    match /{appName}/root/appMeta/{docId} {
      allow read, write: if request.auth != null;
    }

    match /{appName}/root/activityLogs/{docId} {
      allow read, write: if request.auth != null;
    }

    match /{appName}/root/{sub}/{docId} {
      allow read, write: if request.auth != null;
    }

    match /{appName}/root/{sub}/{docId}/{rest=**} {
      allow read, write: if request.auth != null;
    }
  }
}